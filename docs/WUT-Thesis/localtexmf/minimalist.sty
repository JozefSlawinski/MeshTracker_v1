\fi
\if@minimalist@draft
  \@minimalist@fasttrue
\fi
\if@minimalist@puretext
  \@minimalist@nothmstrue
\fi

\if@minimalist@fast
    \PassOptionsToPackage{fast}{PJLdraft}
    \PassOptionsToPackage{fast}{PJLthm}
\fi
