}
\newcommand{\hep@panels@space}{20}
\newenvironment{panels}[2][b]{%
  \newcommand{\begin@subcaption@minipage}[2][b]{%
    \caption@withoptargs\subcaption@minipage[##1]{##2}%
    \centering\vskip 0pt%
  }
