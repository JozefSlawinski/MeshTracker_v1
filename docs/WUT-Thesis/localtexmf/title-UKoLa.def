\DefineFamilyMember[%
  UKoLa%
]{title}
\providecommand*{\presentationinformationUKoLa}{%
  to optain the degree\\
  \@academicgrade\\
  of  \@discipline\\
}
\providecaptionname{american,australian,british,canadian,%
  english,newzealand,UKenglish,USenglish}{\presentationinformationUKoLa}{%
  to optain the degree\\
  \@academicgrade\\
  of  \@discipline\\
}%
